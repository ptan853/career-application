{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RewriteDrafts",
  "type": "object",
  "required": ["schema_version", "target_id", "created_at", "approval_status", "items"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "target_id": { "type": "string" },
    "created_at": { "type": "string" },
    "approval_status": {
      "type": "string",
      "enum": ["needs_event_approval", "approved", "no_events_selected"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "section_id", "status", "heading", "bullets"],
        "properties": {
          "event_id": { "type": "string" },
          "section_id": { "type": "string" },
          "status": { "type": "string", "enum": ["needs_user_approval", "approved"] },
          "target_relevance": { "type": "string" },
          "source_title": { "type": "string" },
          "heading": { "type": "string" },
          "meta": { "type": "string" },
          "factual_inputs_used": { "type": "object" },
          "bullets": { "type": "array", "items": { "type": "object" } },
          "unsupported_or_weak_claims": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
